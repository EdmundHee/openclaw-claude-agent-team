{
  "name": "openclaw-dashboard",
  "version": "1.0.0",
  "description": "OpenClaw Agent Team Dashboard - Visualize Claude Code agent activity",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"cd client && npx vite --port 3001\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite --port 3001",
    "build": "cd client && npx vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
